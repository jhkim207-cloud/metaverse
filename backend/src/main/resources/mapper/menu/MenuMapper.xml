<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.biz.management.menu.mapper.MenuMapper">

    <select id="findAllActive" resultType="com.biz.management.menu.dto.MenuDto">
        SELECT id,
               code,
               name,
               parent_id,
               path,
               icon,
               menu_type,
               sort_order,
               is_active,
               depth
          FROM menus
         WHERE is_active = TRUE
         ORDER BY depth, sort_order
    </select>

</mapper>
