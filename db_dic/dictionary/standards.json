{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.1.0",
  "description": "DB 표준 용어 사전 - 컬럼명, 데이터 타입, 제약조건 표준 정의",

  "_termFormat": {
    "description": "각 용어는 다음 필드를 포함해야 함",
    "required": ["korean", "english", "type", "constraint", "desc"],
    "example": {
      "korean": "한글명",
      "english": "English Name",
      "type": "데이터타입",
      "constraint": "제약조건",
      "desc": "설명"
    }
  },

  "common": {
    "id": {
      "korean": "식별자",
      "english": "Identifier",
      "type": "BIGINT GENERATED ALWAYS AS IDENTITY",
      "constraint": "PRIMARY KEY",
      "desc": "기본 키"
    },
    "created_at": {
      "korean": "생성일시",
      "english": "Created At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NOT NULL DEFAULT now()",
      "desc": "생성일시"
    },
    "updated_at": {
      "korean": "수정일시",
      "english": "Updated At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NOT NULL DEFAULT now()",
      "desc": "수정일시"
    },
    "created_by": {
      "korean": "생성자",
      "english": "Created By",
      "type": "VARCHAR(100)",
      "constraint": "NOT NULL DEFAULT CURRENT_USER",
      "desc": "생성자"
    },
    "updated_by": {
      "korean": "수정자",
      "english": "Updated By",
      "type": "VARCHAR(100)",
      "constraint": "NOT NULL DEFAULT CURRENT_USER",
      "desc": "수정자"
    },
    "is_deleted": {
      "korean": "삭제여부",
      "english": "Is Deleted",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "삭제 여부 (소프트 삭제)"
    },
    "deleted_at": {
      "korean": "삭제일시",
      "english": "Deleted At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "삭제일시"
    },
    "version": {
      "korean": "버전",
      "english": "Version",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 1",
      "desc": "낙관적 락 버전"
    }
  },

  "user": {
    "user_id": {
      "korean": "사용자ID",
      "english": "User ID",
      "type": "BIGINT",
      "constraint": "NOT NULL REFERENCES users(id)",
      "desc": "사용자 FK"
    },
    "employee_id": {
      "korean": "사원번호",
      "english": "Employee ID",
      "type": "VARCHAR(50)",
      "constraint": "NULL",
      "desc": "HR 시스템 연동용 사원번호"
    },
    "organization_id": {
      "korean": "조직ID",
      "english": "Organization ID",
      "type": "BIGINT",
      "constraint": "NULL REFERENCES organizations(id)",
      "desc": "소속 조직 FK"
    },
    "locked_until": {
      "korean": "잠금해제일시",
      "english": "Locked Until",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "계정 잠금 해제 예정 시각"
    },
    "password_changed_at": {
      "korean": "비밀번호변경일시",
      "english": "Password Changed At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "비밀번호 만료 체크용"
    },
    "failed_login_count": {
      "korean": "로그인실패횟수",
      "english": "Failed Login Count",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "연속 로그인 실패 횟수"
    },
    "email": {
      "korean": "이메일",
      "english": "Email",
      "type": "VARCHAR(255)",
      "constraint": "NOT NULL UNIQUE",
      "desc": "이메일 주소"
    },
    "password_hash": {
      "korean": "비밀번호해시",
      "english": "Password Hash",
      "type": "VARCHAR(255)",
      "constraint": "NOT NULL",
      "desc": "비밀번호 해시"
    },
    "username": {
      "korean": "사용자명",
      "english": "Username",
      "type": "VARCHAR(50)",
      "constraint": "NOT NULL UNIQUE",
      "desc": "사용자명"
    },
    "display_name": {
      "korean": "표시명",
      "english": "Display Name",
      "type": "VARCHAR(100)",
      "constraint": "NULL",
      "desc": "표시 이름"
    },
    "phone_number": {
      "korean": "전화번호",
      "english": "Phone Number",
      "type": "VARCHAR(20)",
      "constraint": "NULL",
      "desc": "전화번호"
    },
    "profile_image_url": {
      "korean": "프로필이미지URL",
      "english": "Profile Image URL",
      "type": "VARCHAR(500)",
      "constraint": "NULL",
      "desc": "프로필 이미지 URL"
    },
    "last_login_at": {
      "korean": "최종로그인일시",
      "english": "Last Login At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "마지막 로그인 일시"
    }
  },

  "role": {
    "role_id": {
      "korean": "역할ID",
      "english": "Role ID",
      "type": "BIGINT",
      "constraint": "NOT NULL REFERENCES roles(id)",
      "desc": "역할 FK"
    },
    "is_system": {
      "korean": "시스템역할여부",
      "english": "Is System",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "시스템 역할 여부 (삭제 불가)"
    },
    "role_group_id": {
      "korean": "역할그룹ID",
      "english": "Role Group ID",
      "type": "BIGINT",
      "constraint": "NOT NULL REFERENCES role_groups(id)",
      "desc": "역할 그룹 FK"
    }
  },

  "permission": {
    "resource_type": {
      "korean": "리소스유형",
      "english": "Resource Type",
      "type": "VARCHAR(100)",
      "constraint": "NOT NULL",
      "desc": "권한 대상 유형 (MENU, API, REPORT, DATA)"
    },
    "resource_code": {
      "korean": "리소스코드",
      "english": "Resource Code",
      "type": "VARCHAR(100)",
      "constraint": "NULL",
      "desc": "특정 리소스 식별 코드"
    },
    "resource_id": {
      "korean": "리소스ID",
      "english": "Resource ID",
      "type": "VARCHAR(100)",
      "constraint": "NULL",
      "desc": "대상 리소스의 ID"
    },
    "can_read": {
      "korean": "조회권한",
      "english": "Can Read",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "데이터 조회 가능 여부"
    },
    "can_create": {
      "korean": "생성권한",
      "english": "Can Create",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "데이터 생성 가능 여부"
    },
    "can_update": {
      "korean": "수정권한",
      "english": "Can Update",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "데이터 수정 가능 여부"
    },
    "can_delete": {
      "korean": "삭제권한",
      "english": "Can Delete",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "데이터 삭제 가능 여부"
    },
    "can_submit": {
      "korean": "제출권한",
      "english": "Can Submit",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "문서 제출/확정 가능 여부"
    },
    "can_approve": {
      "korean": "승인권한",
      "english": "Can Approve",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "문서 승인 가능 여부"
    },
    "can_cancel": {
      "korean": "취소권한",
      "english": "Can Cancel",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "확정된 문서 취소 가능 여부"
    },
    "can_export": {
      "korean": "내보내기권한",
      "english": "Can Export",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "데이터 내보내기 가능 여부"
    },
    "perm_level": {
      "korean": "권한레벨",
      "english": "Permission Level",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "필드 레벨 접근 권한 (0=기본)"
    },
    "record_filter": {
      "korean": "레코드필터",
      "english": "Record Filter",
      "type": "TEXT",
      "constraint": "NULL",
      "desc": "행 단위 접근 제어 표현식"
    }
  },

  "menu": {
    "menu_id": {
      "korean": "메뉴ID",
      "english": "Menu ID",
      "type": "BIGINT",
      "constraint": "NOT NULL REFERENCES menus(id)",
      "desc": "메뉴 FK"
    },
    "menu_type": {
      "korean": "메뉴유형",
      "english": "Menu Type",
      "type": "VARCHAR(20)",
      "constraint": "NOT NULL",
      "desc": "메뉴 종류 (GROUP, MENU, LINK)"
    },
    "icon": {
      "korean": "아이콘",
      "english": "Icon",
      "type": "VARCHAR(50)",
      "constraint": "NULL",
      "desc": "아이콘 클래스명"
    }
  },

  "organization": {
    "master_id": {
      "korean": "마스터ID",
      "english": "Master ID",
      "type": "VARCHAR(100)",
      "constraint": "NULL",
      "desc": "외부 시스템 Master data 참조 ID"
    },
    "org_type": {
      "korean": "조직유형",
      "english": "Organization Type",
      "type": "VARCHAR(20)",
      "constraint": "NOT NULL",
      "desc": "조직 종류 (COMPANY, DEPARTMENT, TEAM)"
    },
    "manager_id": {
      "korean": "관리자ID",
      "english": "Manager ID",
      "type": "BIGINT",
      "constraint": "NULL REFERENCES users(id)",
      "desc": "조직 책임자 FK"
    }
  },

  "audit": {
    "action": {
      "korean": "행위",
      "english": "Action",
      "type": "VARCHAR(50)",
      "constraint": "NOT NULL",
      "desc": "수행한 작업 유형"
    },
    "old_values": {
      "korean": "변경전값",
      "english": "Old Values",
      "type": "JSONB",
      "constraint": "NULL",
      "desc": "변경 전 데이터 (JSON)"
    },
    "new_values": {
      "korean": "변경후값",
      "english": "New Values",
      "type": "JSONB",
      "constraint": "NULL",
      "desc": "변경 후 데이터 (JSON)"
    },
    "ip_address": {
      "korean": "IP주소",
      "english": "IP Address",
      "type": "VARCHAR(45)",
      "constraint": "NULL",
      "desc": "클라이언트 IP (IPv4/IPv6)"
    },
    "user_agent": {
      "korean": "사용자에이전트",
      "english": "User Agent",
      "type": "TEXT",
      "constraint": "NULL",
      "desc": "브라우저/클라이언트 정보"
    },
    "error_message": {
      "korean": "오류메시지",
      "english": "Error Message",
      "type": "TEXT",
      "constraint": "NULL",
      "desc": "실패 시 오류 내용"
    },
    "assigned_at": {
      "korean": "할당일시",
      "english": "Assigned At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NOT NULL DEFAULT now()",
      "desc": "역할/권한 부여 시각"
    },
    "assigned_by": {
      "korean": "할당자ID",
      "english": "Assigned By",
      "type": "BIGINT",
      "constraint": "NULL REFERENCES users(id)",
      "desc": "역할/권한을 부여한 사용자 FK"
    }
  },

  "inheritance": {
    "child_group_id": {
      "korean": "하위그룹ID",
      "english": "Child Group ID",
      "type": "BIGINT",
      "constraint": "NOT NULL REFERENCES role_groups(id)",
      "desc": "상속받는 역할 그룹 FK"
    },
    "parent_group_id": {
      "korean": "상위그룹ID",
      "english": "Parent Group ID",
      "type": "BIGINT",
      "constraint": "NOT NULL REFERENCES role_groups(id)",
      "desc": "상속하는 역할 그룹 FK"
    }
  },

  "status": {
    "status": {
      "korean": "상태",
      "english": "Status",
      "type": "VARCHAR(20)",
      "constraint": "NOT NULL DEFAULT 'ACTIVE'",
      "desc": "상태 (ACTIVE, INACTIVE, PENDING, SUSPENDED)",
      "enum": ["ACTIVE", "INACTIVE", "PENDING", "SUSPENDED"]
    },
    "approval_status": {
      "korean": "승인상태",
      "english": "Approval Status",
      "type": "VARCHAR(20)",
      "constraint": "NOT NULL DEFAULT 'PENDING'",
      "desc": "승인 상태 (PENDING, APPROVED, REJECTED)",
      "enum": ["PENDING", "APPROVED", "REJECTED"]
    },
    "is_active": {
      "korean": "활성여부",
      "english": "Is Active",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT TRUE",
      "desc": "활성 여부"
    },
    "is_verified": {
      "korean": "인증여부",
      "english": "Is Verified",
      "type": "BOOLEAN",
      "constraint": "NOT NULL DEFAULT FALSE",
      "desc": "인증 여부"
    }
  },

  "naming": {
    "name": {
      "korean": "이름",
      "english": "Name",
      "type": "VARCHAR(100)",
      "constraint": "NOT NULL",
      "desc": "이름"
    },
    "code": {
      "korean": "코드",
      "english": "Code",
      "type": "VARCHAR(50)",
      "constraint": "NOT NULL UNIQUE",
      "desc": "코드"
    },
    "title": {
      "korean": "제목",
      "english": "Title",
      "type": "VARCHAR(200)",
      "constraint": "NOT NULL",
      "desc": "제목"
    },
    "description": {
      "korean": "설명",
      "english": "Description",
      "type": "TEXT",
      "constraint": "NULL",
      "desc": "설명"
    },
    "content": {
      "korean": "내용",
      "english": "Content",
      "type": "TEXT",
      "constraint": "NULL",
      "desc": "내용"
    },
    "remarks": {
      "korean": "비고",
      "english": "Remarks",
      "type": "TEXT",
      "constraint": "NULL",
      "desc": "비고"
    }
  },

  "ordering": {
    "sort_order": {
      "korean": "정렬순서",
      "english": "Sort Order",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "정렬 순서"
    },
    "priority": {
      "korean": "우선순위",
      "english": "Priority",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "우선순위 (높을수록 높음)"
    },
    "display_order": {
      "korean": "표시순서",
      "english": "Display Order",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "표시 순서"
    }
  },

  "datetime": {
    "start_date": {
      "korean": "시작일",
      "english": "Start Date",
      "type": "DATE",
      "constraint": "NULL",
      "desc": "시작일"
    },
    "end_date": {
      "korean": "종료일",
      "english": "End Date",
      "type": "DATE",
      "constraint": "NULL",
      "desc": "종료일"
    },
    "start_datetime": {
      "korean": "시작일시",
      "english": "Start Datetime",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "시작일시"
    },
    "end_datetime": {
      "korean": "종료일시",
      "english": "End Datetime",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "종료일시"
    },
    "scheduled_at": {
      "korean": "예정일시",
      "english": "Scheduled At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "예정일시"
    },
    "completed_at": {
      "korean": "완료일시",
      "english": "Completed At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "완료일시"
    },
    "expired_at": {
      "korean": "만료일시",
      "english": "Expired At",
      "type": "TIMESTAMP WITH TIME ZONE",
      "constraint": "NULL",
      "desc": "만료일시"
    }
  },

  "numeric": {
    "amount": {
      "korean": "금액",
      "english": "Amount",
      "type": "NUMERIC(18,2)",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "금액"
    },
    "quantity": {
      "korean": "수량",
      "english": "Quantity",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "수량"
    },
    "count": {
      "korean": "횟수",
      "english": "Count",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "횟수"
    },
    "rate": {
      "korean": "비율",
      "english": "Rate",
      "type": "NUMERIC(5,2)",
      "constraint": "NULL",
      "desc": "비율 (%)"
    },
    "score": {
      "korean": "점수",
      "english": "Score",
      "type": "NUMERIC(5,2)",
      "constraint": "NULL",
      "desc": "점수"
    }
  },

  "file": {
    "file_name": {
      "korean": "파일명",
      "english": "File Name",
      "type": "VARCHAR(255)",
      "constraint": "NOT NULL",
      "desc": "파일명"
    },
    "file_path": {
      "korean": "파일경로",
      "english": "File Path",
      "type": "VARCHAR(500)",
      "constraint": "NOT NULL",
      "desc": "파일 경로"
    },
    "file_url": {
      "korean": "파일URL",
      "english": "File URL",
      "type": "VARCHAR(500)",
      "constraint": "NULL",
      "desc": "파일 URL"
    },
    "file_size": {
      "korean": "파일크기",
      "english": "File Size",
      "type": "BIGINT",
      "constraint": "NULL",
      "desc": "파일 크기 (bytes)"
    },
    "file_type": {
      "korean": "파일타입",
      "english": "File Type",
      "type": "VARCHAR(50)",
      "constraint": "NULL",
      "desc": "파일 타입 (MIME type)"
    },
    "original_file_name": {
      "korean": "원본파일명",
      "english": "Original File Name",
      "type": "VARCHAR(255)",
      "constraint": "NULL",
      "desc": "원본 파일명"
    }
  },

  "hierarchy": {
    "parent_id": {
      "korean": "상위ID",
      "english": "Parent ID",
      "type": "BIGINT",
      "constraint": "NULL REFERENCES {table}(id)",
      "desc": "상위 ID (자기 참조)"
    },
    "depth": {
      "korean": "계층깊이",
      "english": "Depth",
      "type": "INTEGER",
      "constraint": "NOT NULL DEFAULT 0",
      "desc": "계층 깊이"
    },
    "path": {
      "korean": "계층경로",
      "english": "Path",
      "type": "VARCHAR(500)",
      "constraint": "NULL",
      "desc": "계층 경로 (예: /1/2/3/)"
    }
  },

  "meta": {
    "metadata": {
      "korean": "메타데이터",
      "english": "Metadata",
      "type": "JSONB",
      "constraint": "NULL",
      "desc": "메타데이터 (JSON)"
    },
