    "file_type": {
      "korean": "파일타입",
      "english": "File Type",
      "type": "VARCHAR(50)",
      "constraint": "NULL",
      "desc": "파일 타입 (MIME type)"
    },
    "original_file_name": {
      "korean": "원본파일명",
      "english": "Original File Name",
      "type": "VARCHAR(255)",
      "constraint": "NULL",
      "desc": "원본 파일명"
