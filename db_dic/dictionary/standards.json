    }
  },

  "file": {
    "file_name": {
      "korean": "파일명",
      "english": "File Name",
      "type": "VARCHAR(255)",
      "constraint": "NOT NULL",
      "desc": "파일명"
    },
    "file_path": {
      "korean": "파일경로",
      "english": "File Path",
      "type": "VARCHAR(500)",
      "constraint": "NOT NULL",
      "desc": "파일 경로"
    },
    "file_url": {
      "korean": "파일URL",
      "english": "File URL",
